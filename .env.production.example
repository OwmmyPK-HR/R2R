# =============================
# R2R Production Configuration
# =============================
# Copy values from this file into your server environment or into a local
# .env file on a self-managed VPS. Do not commit real secrets.

# Flask core
SECRET_KEY=replace-with-a-random-64-char-hex-secret
FLASK_ENV=production
FLASK_DEBUG=0
APP_ENV=production
FLASK_HOST=0.0.0.0
PORT=8000

# Reverse proxy / HTTPS
USE_PROXY_FIX=1
PREFERRED_URL_SCHEME=https
SESSION_COOKIE_SECURE=1
SESSION_COOKIE_HTTPONLY=1
SESSION_COOKIE_SAMESITE=Lax

# Database
DATABASE_URL=postgresql://r2r_user:replace-with-strong-password@db-host:5432/r2r_production

# Admin authentication
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# Application settings
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads
SESSION_LIFETIME_MINUTES=480

# Rate limiter
LIMITER_STORAGE_URI=memory://
WEB_CONCURRENCY=1